# HTTP listen port
PORT=8080

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Database
# Supabase (direct connection) example:
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Supabase pooler example (transaction mode):
# only really need to use when scaled. using direct connection for now.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&default_query_exec_mode=simple_protocol
DATABASE_URL=postgres://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_MIGRATIONS_DIR=./db/migrations
# Keep true until schema is created, then consider false for production rollouts.
DB_MIGRATE_ON_STARTUP=true
DB_SCHEMA_CHECK_ON_STARTUP=true

# JWT
JWT_ISSUER=http://localhost:8080/
JWT_AUDIENCE=s3_service
JWT_JWKS_URL=http://localhost:8080/.well-known/jwks.json
JWT_ENABLED=false

# Local docker-compose defaults (hot reload API via Air):
# - API:      http://localhost:8080 (auto-rebuild on .go changes)
# - Optional LocalStack (profile aws): localhost:4566